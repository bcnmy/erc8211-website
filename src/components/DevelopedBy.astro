---
---

<section class="min-h-[25vh] sm:min-h-[33vh] flex items-center border-b border-ink-100 bg-white">
  <div class="article-container w-full py-10 sm:py-14">
    <div class="flex items-center justify-center gap-8 sm:gap-12">

      <a
        href="https://www.biconomy.io"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:opacity-75 transition-opacity"
      >
        <img src="/biconomy-full-logo.svg" alt="Biconomy" class="h-10 sm:h-14" />
      </a>

      <span class="text-2xl sm:text-3xl font-light text-ink-200 select-none">&times;</span>

      <a
        href="https://ethereum.foundation"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 sm:gap-3 hover:opacity-75 transition-opacity"
      >
        <img src="/ef-logo.png" alt="Ethereum Foundation" class="h-12 sm:h-16" />
      </a>

    </div>

  </div>
</section>

<section id="demo" class="py-14 sm:py-20 border-b border-ink-100">
  <div class="article-container">
    <h2 class="text-3xl sm:text-4xl font-bold mb-3">See it in action</h2>
    <p class="text-ink-500 mb-10 sm:mb-14 max-w-xl">
      Interactive demo of Smart Batching — runtime-resolved parameters and predicate-gated execution, live on-chain.
    </p>

    <div class="w-full overflow-hidden rounded-xl border border-ink-100 shadow-sm">
      <iframe
        src="https://erc8211-demo.vercel.app/"
        title="Smart Batching Demo"
        width="100%"
        height="700"
        class="block w-full"
        style="border:none;"
        loading="lazy"
        allow="clipboard-write"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>
